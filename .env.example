PORT=8000
HOST=0.0.0.0
GCS_BUCKET=renal-data-ganesh-20260521
DATABASE_URL=postgres://renal_app:CHANGE_ME@127.0.0.1:5432/renal_portal
# Alternative to DATABASE_URL (use this when password has special characters)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=disable
MAX_BODY_BYTES=314572800
MAX_CHUNK_BYTES=8388608
UPLOAD_CHUNK_BYTES=5242880

# Auth — set these before running in production
# AUTH_SECRET: random secret for HMAC token signing (auto-generated at startup if unset)
AUTH_SECRET=

# Env-var credential bridge (used when DATABASE_URL is not yet configured)
# Admin login: username=admin, password=<ADMIN_PASSWORD>
ADMIN_PASSWORD=changeme_before_production

# Hospital logins: username=<hospitalId>, password=<value>
# Example: SH-SLM-TN logs in with username "SH-SLM-TN" and the password set here
HOSPITAL_CREDENTIALS_JSON={"SCMC-RMN-KA":"<password>","SH-SLM-TN":"<password>","JSS-MYS-KA":"<password>","NH-BLR-KA":"<password>","MIL-NDL-DL":"<password>"}
